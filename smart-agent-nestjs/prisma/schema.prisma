// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum UserRole {
  admin
  manager
  staff
}

enum AppointmentStatus {
  scheduled
  confirmed
  completed
  canceled
  no_show
}

enum NoShowAction {
  block_booking
  require_deposit
  manual_approval
}

model Business {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  slug        String?
  phone       String?
  email       String   @unique
  active      Boolean  @default(false)
  timezone    String   @default("America/Sao_Paulo")
  createdAt   DateTime @default(now()) @map("created_at")

  users            User[]
  professionals    Professional[]
  services         Service[]
  clients          Client[]
  appointments     Appointment[]
  noShowRules      NoShowRule[]

  @@map("businesses")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  userRole     UserRole @default(admin) @map("user_role")
  businessId   String   @db.Uuid @map("business_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime? @map("updated_at")

  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid @map("user_id")
  tokenHash  String   @map("token_hash")
  createdAt  DateTime @default(now()) @map("created_at")
  expiresAt  DateTime? @map("expires_at")
  revoked    Boolean  @default(false)

  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Professional {
  id          Int      @id @default(autoincrement())
  businessId  String   @db.Uuid @map("businesses_id")
  name        String
  specialty   String
  isActive    Boolean  @default(false) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  availabilities Availability[]
  appointments   Appointment[]

  @@map("professionals")
}

model Service {
  id              Int      @id @default(autoincrement())
  businessId      String   @db.Uuid @map("businesses_id")
  name            String
  durationMinutes String   @map("duration_minutes")
  price           String
  createdAt       DateTime @default(now()) @map("created_at")

  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@map("services")
}

model Client {
  id                String   @id @default(uuid()) @db.Uuid
  businessId        String   @db.Uuid @map("businesses_id")
  name              String
  phone             String
  email             String   @unique
  noShowCount       Int?     @map("no_show_count")
  totalAppointments Int?     @map("total_appointments")
  createdAt         DateTime @default(now()) @map("created_at")

  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@map("clients")
}

model Availability {
  id             Int    @id @default(autoincrement())
  professionalId Int    @map("professional_id")
  dayOfWeek      String @map("day_of_week")
  startTime      String @map("start_time")
  endTime        String @map("end_time")

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@map("availabilities")
}

model Appointment {
  id             Int                @id @default(autoincrement())
  businessId     String             @db.Uuid @map("businesses_id")
  professionalId Int                @map("professional_id")
  clientId       String             @db.Uuid @map("client_id")
  serviceId      Int                @map("service_id")
  date           String
  startTime      String             @map("start_time")
  endTime        String             @map("end_time")
  status         AppointmentStatus?
  cancelReason   String?            @map("cancel_reason")
  confirmAt      DateTime?          @map("confirm_at")
  createdAt      DateTime           @default(now()) @map("created_at")

  business      Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  professional  Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  client        Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service       Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  notifications NotificationLog[]

  @@map("appointment")
}

model NotificationLog {
  id            Int      @id @default(autoincrement())
  appointmentId Int      @map("appointment_id")
  type          String
  sendAt        DateTime @default(now()) @map("send_at")
  status        String   @default("sent")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("notification_logs")
}

model NoShowRule {
  id             Int          @id @default(autoincrement())
  businessId     String?      @db.Uuid @map("businesses_id")
  maxRatePercent Int?         @map("max_rate_percent")
  action         NoShowAction?
  createdAt      DateTime     @default(now()) @map("created_at")

  business Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("no_show_rules")
}